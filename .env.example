DEBUG=false
HOST=0.0.0.0
PORT=8080
API_PREFIX=/v1
CORS_ORIGINS=["http://localhost:3000"]
# Postgres credentials — used by Docker Compose to configure the database container
# and to construct DATABASE_URL for the server container automatically.
POSTGRES_USER=papyrus
POSTGRES_PASSWORD=papyrus
POSTGRES_DB=papyrus

# Only needed when running the server outside Docker (e.g. uv run uvicorn ...)
# DATABASE_URL=postgresql+asyncpg://papyrus:papyrus@localhost:5432/papyrus

SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_AUTH=5
RATE_LIMIT_GENERAL=100
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_BATCH=20